; Заголовок .WMF для Wild Commander, формат #0A.
; Страница 0 содержит код. Страницы 1..16 образуют буфер STOR размером 256 КиБ.
; Заголовок физически занимает 512 байтов. Поля, не используемые инструментом
; меню типа #03, заполняются нулями/резервом, чтобы код начинался с границы сектора.

        ds 16
        db "WildCommanderMDL"
        db #0A
        db 0
        db 17                         ; всего страниц: код + 16 страниц STOR
        db 0                          ; страница 0 подключается по адресу #8000

        ; Первая пара описывает страницу 0: смещение и число 512-байтных секторов
        ; кода с округлением вверх. Остальные пары зарезервированы форматом WMF.
        db 0,(mainEnd-mainStart+511)/512
        db 0,0
        db 0,0
        db 0,0
        db 0,0
        db 0,0

        ds 16
        ds 32*3
        db 0
        dd 0                          ; инструмент меню, не привязанный к выбранному файлу

.plugin_name
        db "ZiFi FTP Server v0.10"
        ds 32-($-.plugin_name),' '
        db #03                        ; запуск из меню плагинов
        ds 6
        ds 32                         ; резерв заголовка для плагина типа #03
